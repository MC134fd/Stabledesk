# StableDesk — Environment Variable Template
# Copy this file to .env and fill in real values. Never commit .env.

# Solana RPC endpoint (mainnet, devnet, or localnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Treasury wallet keypair (base58 private key or JSON array)
TREASURY_KEYPAIR=

# USDC mint address on the target cluster
# Devnet USDC: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Kamino lending market address (Main market)
KAMINO_MARKET_ADDRESS=7u3HeHxYDLhnCoErrtycNokbQYbWGzLs6JSDqGAv5PfF
KAMINO_PROGRAM_ID=

# Kora gas abstraction (leave empty to use direct signing with SOL)
KORA_ENDPOINT=
KORA_API_KEY=
# Fee token mint for Kora (defaults to USDC_MINT_ADDRESS if empty)
KORA_FEE_TOKEN=

# Scheduler interval in seconds
SCHEDULER_INTERVAL_SECONDS=60

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# API server port
PORT=3000
