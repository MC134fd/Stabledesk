SOLANA_RPC_URL=

# TODO: Treasury wallet keypair path or base58 private key
TREASURY_KEYPAIR=

# TODO: USDC mint address on the target cluster
USDC_MINT_ADDRESS=

# TODO: Kamino program/market addresses
KAMINO_PROGRAM_ID=
KAMINO_MARKET_ADDRESS=

# TODO: Scheduler interval in seconds
SCHEDULER_INTERVAL_SECONDS=60

# TODO: Log level (debug | info | warn | error)
LOG_LEVEL=info
