{
  "name": "stabledesk",
  "version": "0.1.0",
  "description": "Autonomous institutional stablecoin treasury backend on Solana",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "show-state": "tsx src/scripts/show-state.ts",
    "create-payment": "tsx src/scripts/create-payment.ts",
    "scheduler": "tsx src/scripts/run-scheduler.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@kamino-finance/klend-sdk": "^7.3.20",
    "@solana/kora": "^0.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8"
  }
}
